# Database Configuration
DB_USER=postgres
DB_PASSWORD=your_password
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ecowallet
DB_SSL=false
DATABASE_URL=

# JWT Configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production

# Server Configuration
PORT=3000
NODE_ENV=development

# CORS Configuration
FRONTEND_URL=http://localhost:5500

# Google OAuth (Sign-in with Google)
GOOGLE_CLIENT_ID=

# Password Reset
PASSWORD_RESET_TOKEN_TTL_MINUTES=60
PASSWORD_RESET_URL=http://localhost:5500

# SMTP (optional; if not set, reset link is logged to server console)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM=
SMTP_SECURE=false
