{
  "version": 2,
  "routes": [
    { "src": "/", "dest": "/index.html" },
    { "src": "/about/?", "dest": "/about.html" },
    { "src": "/services/?", "dest": "/services.html" },
    { "src": "/login/?", "dest": "/login.html" },
    { "src": "/register/?", "dest": "/register.html" },
    { "src": "/forgot-password/?", "dest": "/forgot-password.html" },
    { "src": "/reset-password/?", "dest": "/reset-password.html" },
    { "src": "/dashboard/?", "dest": "/dashboard.html" },
    { "src": "/admin/?", "dest": "/admin.html" },
    { "src": "/admin-login/?", "dest": "/admin-login.html" },
    { "src": "/agent/?", "dest": "/agent.html" },
    { "src": "/(.*)", "dest": "/$1" }
  ],
  "cleanUrls": true,
  "trailingSlash": false
}
